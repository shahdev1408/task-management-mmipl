generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  role      String   @default("EXECUTOR")
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  managedActivities Activity[]       @relation("ActivityManager")
  executedSubTasks  SubTask[]        @relation("SubTaskExecutor")
  createdTasks      Task[]           @relation("TaskCreator")
  subTaskHistory    SubTaskHistory[] @relation("SubTaskHistoryChanger")
}

model Project {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  day0      DateTime
  createdAt DateTime @default(now())
  tasks     Task[]
}

model TaskTemplate {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime           @default(now())
  activities  ActivityTemplate[]
  tasks       Task[]
}

model ActivityTemplate {
  id            Int               @id @default(autoincrement())
  templateId    Int
  template      TaskTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  name          String
  description   String?
  estimatedDays Int               @default(1)
  sortOrder     Int               @default(0)
  subTasks      SubTaskTemplate[]
}

model SubTaskTemplate {
  id                 Int              @id @default(autoincrement())
  activityId         Int
  activity           ActivityTemplate @relation(fields: [activityId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  name               String
  description        String?
  defaultDays        Int              @default(1)
  precedenceType     String           @default("NONE")
  attachmentRequired String?          // NEW — e.g. "PDF", "ZIP", "Any"
  sortOrder          Int              @default(0)
}

model Task {
  id          Int          @id @default(autoincrement())
  projectId   Int
  project     Project      @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  templateId  Int
  template    TaskTemplate @relation(fields: [templateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById Int
  createdBy   User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status      String       @default("ONGOING")
  createdAt   DateTime     @default(now())
  activities  Activity[]
}

model Activity {
  id            Int       @id @default(autoincrement())
  taskId        Int
  task          Task      @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  managerId     Int
  manager       User      @relation("ActivityManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  name          String
  estimatedDays Int
  status        String    @default("ONGOING")
  createdAt     DateTime  @default(now())
  subTasks      SubTask[]
}

model SubTask {
  id                 Int              @id @default(autoincrement())
  activityId         Int
  activity           Activity         @relation(fields: [activityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  executorId         Int
  executor           User             @relation("SubTaskExecutor", fields: [executorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  name               String
  days               Int
  dueDate            DateTime?
  scheduledDate      DateTime?
  precedenceType     String           @default("NONE")
  precedingSubTaskId Int?
  status             String           @default("ALLOTTED")
  rating             Int?
  submissionStatus   String?
  remark             String?
  attachmentPath     String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  history            SubTaskHistory[]
}

model SubTaskHistory {
  id          Int      @id @default(autoincrement())
  subTaskId   Int
  subTask     SubTask  @relation(fields: [subTaskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  changedById Int
  changedBy   User     @relation("SubTaskHistoryChanger", fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  oldStatus   String
  newStatus   String
  note        String?
  changedAt   DateTime @default(now())
}